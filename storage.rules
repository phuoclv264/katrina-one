rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to recruitment photos (needed for staff to view applications)
    match /recruitment/{fileName} {
      allow read;
      allow write: if request.auth != null;
    }

    // Default rule: authenticated users only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
